# Cover-art ETL pipeline (scripts/fetch_covers.py)
# Get a free key: https://www.steamgriddb.com/profile/preferences/api
STEAMGRIDDB_API_KEY=
# Get a free key: https://rawg.io/apidocs
RAWG_API_KEY=

# Supabase upload step (scripts/upload_to_supabase.py)
# Project Settings -> API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# service_role key -- NEVER expose this in the frontend, local/CI use only
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=game-covers
